menu "KC Device Options"

config KC_SD_LOGGER_ENABLED
    bool "Enable SD card sensor logging"
    default y if IDF_TARGET_ESP32S3
    default n
    help
        Enable the background task that writes sensor snapshots to an SD card
        using the SDSPI host driver. This feature is intended for the ESP32-S3
        dashboard build where a microSD slot is wired to the FSPI pins.

config KC_SD_LOG_INTERVAL_SEC
    int "SD log interval (seconds)"
    depends on KC_SD_LOGGER_ENABLED
    range 5 3600
    default 60
    help
        Sampling interval for writing sensor cache snapshots to disk. Each entry
        is written as a newline-delimited JSON document. Values below 5 seconds
        are clamped to 5 seconds at runtime.

config KC_SD_SPI_HOST
    int "SDSPI host (2 = FSPI, 3 = HSPI)"
    depends on KC_SD_LOGGER_ENABLED
    range 1 3
    default 2 if IDF_TARGET_ESP32S3
    default 2
    help
        Select which SPI host is reserved for the SD card. ESP32-S3 boards
        typically wire the SD slot to FSPI (host 2). ESP32-C6 boards should keep
        the logger disabled unless an external slot is wired up.

config KC_SD_SPI_MAX_FREQ_KHZ
    int "SDSPI clock frequency (kHz)"
    depends on KC_SD_LOGGER_ENABLED
    range 400 32000
    default 12000
    help
        Maximum SPI clock used when talking to the SD card. Lower frequencies
        improve signal integrity on long traces; higher frequencies increase
        throughput.

config KC_SD_SPI_MISO_GPIO
    int "SD card MISO GPIO"
    depends on KC_SD_LOGGER_ENABLED
    range 0 48
    default 13

config KC_SD_SPI_MOSI_GPIO
    int "SD card MOSI GPIO"
    depends on KC_SD_LOGGER_ENABLED
    range 0 48
    default 11

config KC_SD_SPI_CLK_GPIO
    int "SD card CLK GPIO"
    depends on KC_SD_LOGGER_ENABLED
    range 0 48
    default 12

config KC_SD_SPI_CS_GPIO
    int "SD card CS GPIO"
    depends on KC_SD_LOGGER_ENABLED
    range 0 48
    default 10

config KC_SD_CARD_DETECT_GPIO
    int "Card detect GPIO (-1 to disable)"
    depends on KC_SD_LOGGER_ENABLED
    range -1 48
    default -1
    help
        Optional GPIO input wired to the SD slot card-detect switch. Set to -1
        if the board does not expose a detect pin.

config KC_SD_CARD_DETECT_ACTIVE_LOW
    bool "Card detect is active-low"
    depends on KC_SD_LOGGER_ENABLED
    default y
    help
        Set to Y when the card-detect line reads LOW while a card is inserted.
        Leave enabled for most slots; disable when the detect pin is active-high.

endmenu
