# Bluetooth configuration (based on ESP-IDF v5.5 examples)
CONFIG_BT_ENABLED=y
CONFIG_BT_BLE_42_FEATURES_SUPPORTED=y

# WiFi configuration
CONFIG_ESP_WIFI_AUTH_WPA2_PSK=y

# NVS Storage
# NVS encryption enabled for secure credential storage
CONFIG_NVS_ENCRYPTION=y
CONFIG_NVS_SEC_KEY_PROTECTION_SCHEME=y
CONFIG_NVS_SEC_KEY_PROTECT_USING_FLASH_ENC=n
CONFIG_NVS_SEC_KEY_PROTECT_USING_HMAC=y

# FreeRTOS
CONFIG_FREERTOS_HZ=1000
CONFIG_FREERTOS_USE_TRACE_FACILITY=y
CONFIG_FREERTOS_GENERATE_RUN_TIME_STATS=y
CONFIG_FREERTOS_RUN_TIME_STATS_USING_ESP_TIMER=y

# Flash size
CONFIG_ESPTOOLPY_FLASHSIZE_4MB=y

# Partition table
CONFIG_PARTITION_TABLE_CUSTOM=y
CONFIG_PARTITION_TABLE_CUSTOM_FILENAME="partitions.csv"

# FATFS
CONFIG_FATFS_LFN_STACK=y

# SD logger (ESP32-S3 dashboard build)
CONFIG_KC_SD_LOGGER_ENABLED=y
CONFIG_KC_SD_LOG_INTERVAL_SEC=60
CONFIG_KC_SD_SPI_HOST=2
CONFIG_KC_SD_SPI_MAX_FREQ_KHZ=12000
CONFIG_KC_SD_SPI_MISO_GPIO=13
CONFIG_KC_SD_SPI_MOSI_GPIO=11
CONFIG_KC_SD_SPI_CLK_GPIO=12
CONFIG_KC_SD_SPI_CS_GPIO=10
CONFIG_KC_SD_CARD_DETECT_GPIO=-1
CONFIG_KC_SD_CARD_DETECT_ACTIVE_LOW=y

# Log levels
CONFIG_LOG_DEFAULT_LEVEL_INFO=y
CONFIG_LOG_MAXIMUM_LEVEL_VERBOSE=y

# Flash Encryption - DISABLED for development flexibility
# Keeping flash unencrypted allows unlimited reflashing during development
# NVS encryption alone provides MEDIUM security for WiFi credentials
# Uncomment below to enable (WARNING: IRREVERSIBLE, limits reflashing)
# CONFIG_SECURE_FLASH_ENC_ENABLED=y
# CONFIG_SECURE_FLASH_ENCRYPTION_MODE_DEVELOPMENT=y
# CONFIG_SECURE_FLASH_REQUIRE_ALREADY_ENABLED=n
CONFIG_SECURE_FLASH_UART_BOOTLOADER_ALLOW_ENC=y
CONFIG_SECURE_FLASH_UART_BOOTLOADER_ALLOW_DEC=y
CONFIG_SECURE_FLASH_UART_BOOTLOADER_ALLOW_CACHE=y

# ESP32-S3 specific
CONFIG_IDF_TARGET="esp32s3"
